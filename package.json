{
  "name": "personal-portfolio",
  "version": "1.0.0",
  "description": "My Personal Portfolio Website to demonstrate my Web Dev Skills",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "cd frontend && pnpm run dev",
    "install:all": "pnpm run install:front && pnpm run install:back",
    "install:front": "cd frontend && pnpm install",
    "install:back": "cd backend && pnpm install",
    "build:front": "cd frontend && pnpm run build",
    "build:back": "cd backend && pnpm run build",
    "build:all": "pnpm run build:front && pnpm run build:back",
    "typecheck:front": "cd frontend && pnpm exec tsc --noEmit",
    "typecheck:back": "cd backend && pnpm exec tsc --noEmit",
    "typecheck": "pnpm run typecheck:front && pnpm run typecheck:back",
    "deploy": "cd backend && pnpm run deploy"
  },
  "engines": { "node": ">=18" },
  "keywords": ["Personal Portfolio", "Blog"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "mongodb": "^6.18.0"
  }
}
